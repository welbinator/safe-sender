POSTGRES_DB=sendersafety
POSTGRES_USER=sendersafety
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://sendersafety:changeme@postgres:5432/sendersafety

# Backend / internal
JWT_SECRET=changeme
ADMIN_SECRET=changeme
INTERNAL_SHARED_SECRET=changeme
ADMIN_EMAIL=
ALLOW_TEST_TOKENS=0
REDIS_URL=redis://redis:6379/0

# Mailgun — API (backend uses for transactional sends + webhook signing)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.sendersafety.com
FROM_EMAIL=relay@mg.sendersafety.com
MAILGUN_WEBHOOK_SIGNING_KEY=

# Mailgun — SMTP relay (smtp service forwards outbound mail through here)
MAILGUN_SMTP_HOST=smtp.mailgun.org
MAILGUN_SMTP_PORT=587
MAILGUN_SMTP_LOGIN=
MAILGUN_SMTP_PASSWORD=

# SMTP relay auth (Google Workspace clients authenticate to OUR smtp with these)
SMTP_AUTH_USERNAME=
SMTP_AUTH_PASSWORD=

# TLS certificate paths (Let's Encrypt)
TLS_CERT_PATH=/etc/letsencrypt/live/smtp.sendersafety.com/fullchain.pem
TLS_KEY_PATH=/etc/letsencrypt/live/smtp.sendersafety.com/privkey.pem

# Port 25 ingress whitelist (CIDRs, comma-separated). Empty = block.
PORT25_ALLOWED_CIDRS=

# OAuth (Sprint 3)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP gateway smoke-test (F-15) — used by /customers/test-connection
SMTP_GATEWAY_HOST=smtp.sendersafety.com
SMTP_GATEWAY_PORT=587
SMTP_TEST_RECIPIENT=delivery-test@sendersafety.com
SMTP_TEST_POLL_DEADLINE_SECS=10

# Sentry (F-58) — runtime error monitoring.
# Each service has its own DSN/project; leave blank to disable in local dev.
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_DSN_BACKEND=
SENTRY_DSN_SMTP=
# SENTRY_RELEASE is injected automatically by deploy.sh from git SHA.

# Dashboard (Vite) — baked into the SPA at build time via nginx Dockerfile args.
VITE_API_URL=/api
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=local
VITE_SENTRY_TRACES_SAMPLE_RATE=0.05
VITE_SENTRY_RELEASE=
