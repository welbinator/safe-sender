POSTGRES_DB=sendersafety
POSTGRES_USER=sendersafety
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://sendersafety:changeme@postgres:5432/sendersafety

# AWS SES credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
SES_SOURCE_ARN=
SES_FROM_EMAIL=relay@sendersafety.com

# SMTP relay auth (Google Workspace uses these)
SMTP_AUTH_USERNAME=
SMTP_AUTH_PASSWORD=

# TLS certificate paths (Let's Encrypt)
TLS_CERT_PATH=/etc/letsencrypt/live/smtp.sendersafety.com/fullchain.pem
TLS_KEY_PATH=/etc/letsencrypt/live/smtp.sendersafety.com/privkey.pem

# SSL paths for nginx (prod)
SSL_CERT_PATH=
SSL_KEY_PATH=

# OAuth (Sprint 3)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=changeme

# SMTP gateway smoke-test (F-15) — used by /customers/test-connection
# Defaults match production; override per env (e.g. staging.smtp.sendersafety.com).
SMTP_GATEWAY_HOST=smtp.sendersafety.com
SMTP_GATEWAY_PORT=587
SMTP_TEST_RECIPIENT=delivery-test@sendersafety.com
SMTP_TEST_POLL_DEADLINE_SECS=10
